# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment — note the bare `env` rule: a file literally named `env` (no dot) slips past
# `.env*` and that's how live secrets were previously committed. Keep this line.
env
.env
.env.*
!.env.example

# MCP — local AUTH_TOKEN lives in .mcp.json; commit .mcp.json.example instead.
.mcp.json

