// The Growth Project: Finance — Prisma Schema
// PostgreSQL with multi-tenant architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  coach
  student
  owner
}

// CoachPracticeType — Stage-3 cross-pillar federation gate.
//
// What kind of practice the coach runs across the TGP product family
// (Body / Wealth). The cross-pillar federation surface in
// `/api/coach/cross-pillar/*` is gated on `both`; coaches with
// `fitness_only` or `finance_only` see their existing single-product
// coach console unchanged. `null` on the User row means the coach has
// not yet selected — the cross-pillar surface returns
// `403 PRACTICE_NOT_SELECTED` and the mobile app routes them through
// the practice-selection flow.
enum CoachPracticeType {
  fitness_only
  finance_only
  both
}

enum AccountType {
  checking
  savings
  investment_brokerage
  retirement_401k
  retirement_ira
  real_estate
  vehicle
  other_asset
  credit_card
  personal_loan
  student_loan
  auto_loan
  mortgage
  medical_debt
  other_debt
}

enum RiskTolerance {
  conservative
  moderate
  aggressive
}

enum MotivationStyle {
  small_wins
  big_picture
}

enum LogSource {
  eod_form
  manual_update
  onboarding
}

enum ScenarioType {
  extra_debt_payment
  income_increase
  relocate_country
  relocate_city
  cut_expense
  invest_lump_sum
  sell_asset
  start_business
  pay_off_debt_early
  salary_negotiation
  tax_optimization
  retire_early
}

// ============================================================
// MODELS
// ============================================================

model User {
  id            String   @id @default(uuid())
  supabase_id   String   @unique
  email         String   @unique
  name          String
  phone         String?
  referral_code String?
  role          Role     @default(student)
  coach_id      String? // For students: which coach manages them
  // Stage-3 cross-pillar federation. Only meaningful when `role = coach`
  // or `owner`; ignored for students. Null = not yet selected.
  coach_practice_type CoachPracticeType?
  created_at    DateTime @default(now())

  // Relations
  profile              FinancialProfile?
  accounts             FinancialAccount[]
  eod_submissions      EODSubmission[]
  what_if_scenarios    WhatIfScenario[]
  notification_prefs   NotificationPreferences?
  habit_logs           HabitLog[]
  milestones           MilestoneUnlock[]
  accountability_pair  String? // partner user_id (privacy: only scores/streaks shown)
  coach_notes_received CoachNote[]              @relation("StudentNotes")
  coach_notes_sent     CoachNote[]              @relation("CoachNotes")
  program_templates    ProgramTemplate[]
  community_wins       CommunityWin[]
  preferences          UserPreferences?
  coach_profile        CoachProfile?
  // Stage 2 — coach OS additions
  assignments_assigned    ClientAssignment[] @relation("AssignmentsByCoach")
  assignments_received    ClientAssignment[] @relation("AssignmentsForClient")
  coach_messages_sent     CoachMessage[]     @relation("CoachMessagesSent")
  coach_messages_received CoachMessage[]     @relation("CoachMessagesReceived")
  community_posts         CommunityPost[]    @relation("CommunityPostsAuthored")
  // Sprint A — multi-code invite flow (parity with fitness backend).
  invite_codes_issued     InviteCode[]       @relation("InviteCodesByCoach")
  coach_promotion_audits  CoachPromotionAudit[]

  @@map("users")
}

// CoachProfile: per-coach tenant metadata. Created when a user is promoted to
// `coach` (or `owner`) and is the source of truth for the coach's invite_code,
// which is the share-link token clients use to sign up under that coach.
//
// Why a separate table:
//  - keeps invite_code/display_name out of User (which all users share)
//  - lets us add coach-only fields (capacity, billing hooks) without bloating User
//  - admin/owner promotion can ensure-create this row idempotently
model CoachProfile {
  id           String   @id @default(uuid())
  user_id      String   @unique
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  invite_code  String   @unique
  display_name String?
  bio          String?
  is_active    Boolean  @default(true)
  capacity     Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("coach_profiles")
}

model FinancialProfile {
  id                      String          @id @default(uuid())
  user_id                 String          @unique
  user                    User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  state                   String?
  city                    String?
  country                 String          @default("United States")
  monthly_income_gross    Decimal?        @db.Decimal(14, 2)
  annual_income_gross     Decimal?        @db.Decimal(14, 2)
  income_sources          Json? // array of { source, amount, frequency }
  primary_goal            String?
  goal_timeline_months    Int?
  dream_lifestyle_cost_mo Decimal?        @db.Decimal(14, 2)
  dream_description       String?
  future_self_letter      String? // Written during onboarding, revealed at day 90
  risk_tolerance          RiskTolerance   @default(moderate)
  is_self_employed        Boolean         @default(false)
  has_business            Boolean         @default(false)
  motivation_style        MotivationStyle @default(big_picture)
  net_worth_snapshot      Decimal?        @db.Decimal(14, 2) // Updated on every EOD submission
  total_debt              Decimal?        @db.Decimal(14, 2) // Computed sum of all debt balances
  total_assets            Decimal?        @db.Decimal(14, 2) // Computed sum of all asset balances
  total_cash              Decimal?        @db.Decimal(14, 2) // Computed sum of checking + savings
  current_priority_index  Int             @default(0) // Index in PRIORITY_WATERFALL
  wealth_velocity_score   Float? // 0-100, updated daily — score, not money
  last_eod_date           DateTime?
  filing_status           String          @default("single") // for tax estimator
  onboarding_complete     Boolean         @default(false)
  payday_templates        Json? // array of { id, name, allocations: [{account_id, percentage}], created_at }
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt

  @@map("financial_profiles")
}

model FinancialAccount {
  id              String              @id @default(uuid())
  user_id         String
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name            String // e.g., "Chase Sapphire", "Car Loan", "Roth IRA"
  account_type    AccountType
  institution     String?
  balance         Decimal             @db.Decimal(14, 2) // Current balance (positive for assets AND debt)
  is_debt         Boolean             @default(false)
  apr_percent     Float? // For debt accounts — percentage, not money
  is_secured      Boolean? // true for mortgage/car, false for credit card/personal loan
  minimum_payment Decimal?            @db.Decimal(14, 2)
  currency        String              @default("USD")
  notes           String?
  is_active       Boolean             @default(true)
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  balance_logs    AccountBalanceLog[]

  @@map("financial_accounts")
}

model AccountBalanceLog {
  id         String           @id @default(uuid())
  account_id String
  account    FinancialAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  balance    Decimal          @db.Decimal(14, 2)
  date       DateTime         @db.Date
  logged_at  DateTime         @default(now())
  source     LogSource        @default(eod_form)

  @@map("account_balance_logs")
}

model EODSubmission {
  id                    String   @id @default(uuid())
  user_id               String
  user                  User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  submission_date       DateTime @db.Date
  account_snapshots     Json // array of { account_id, balance, notes }
  net_worth_computed    Decimal  @db.Decimal(14, 2)
  total_debt_computed   Decimal  @db.Decimal(14, 2)
  total_assets_computed Decimal  @db.Decimal(14, 2)
  total_cash_computed   Decimal  @db.Decimal(14, 2)
  notes                 String?
  mood                  Int? // 1-5 optional
  ai_insight            String? // AI-generated insight after submission
  habits_checked        Json? // array of checked habit keys
  submitted_at          DateTime @default(now())

  @@unique([user_id, submission_date])
  @@map("eod_submissions")
}

model WhatIfScenario {
  id              String       @id @default(uuid())
  user_id         String
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  scenario_type   ScenarioType
  label           String
  parameters      Json // Flexible key-value for scenario inputs
  result_summary  Json // Computed outputs
  projection_1yr  Decimal?     @db.Decimal(14, 2)
  projection_3yr  Decimal?     @db.Decimal(14, 2)
  projection_5yr  Decimal?     @db.Decimal(14, 2)
  projection_10yr Decimal?     @db.Decimal(14, 2)
  created_at      DateTime     @default(now())

  @@map("what_if_scenarios")
}

model MilestoneUnlock {
  id            String   @id @default(uuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  milestone_key String
  unlocked_at   DateTime @default(now())
  celebrated    Boolean  @default(false)

  @@unique([user_id, milestone_key])
  @@map("milestone_unlocks")
}

model NotificationPreferences {
  id                          String  @id @default(uuid())
  user_id                     String  @unique
  user                        User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  eod_reminder_enabled        Boolean @default(true)
  eod_reminder_time           String  @default("20:00")
  milestone_alerts            Boolean @default(true)
  coach_messages              Boolean @default(true)
  red_flag_alerts             Boolean @default(true)
  future_self_letter_enabled  Boolean @default(true)
  priority_levelup_alerts     Boolean @default(true)
  spending_dna_alerts         Boolean @default(true)
  timezone                    String  @default("America/Los_Angeles")
  expo_push_token             String? // For Expo push notifications

  @@map("notification_preferences")
}

model HabitLog {
  id        String   @id @default(uuid())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  habit_key String // e.g., "no_impulse_buy", "checked_balances", "reviewed_budget"
  date      DateTime @db.Date
  completed Boolean  @default(true)
  logged_at DateTime @default(now())

  @@unique([user_id, habit_key, date])
  @@map("habit_logs")
}

model CoachNote {
  id         String   @id @default(uuid())
  coach_id   String
  coach      User     @relation("CoachNotes", fields: [coach_id], references: [id])
  student_id String
  student    User     @relation("StudentNotes", fields: [student_id], references: [id])
  note       String
  is_private Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("coach_notes")
}

model ProgramTemplate {
  id          String   @id @default(uuid())
  coach_id    String
  coach       User     @relation(fields: [coach_id], references: [id])
  name        String
  description String?
  phases      Json // array of { phase_name, priority_index, duration_weeks, notes }
  created_at  DateTime @default(now())

  @@map("program_templates")
}

model PushLog {
  id      String   @id @default(uuid())
  user_id String
  type    String // e.g., eod_reminder, net_worth_milestone, priority_levelup, future_self_letter, spending_dna
  title   String
  body    String
  data    Json? // arbitrary payload (milestone key, priority index, etc.) — used for event-dedupe
  sent_at DateTime @default(now())
  error   String?

  @@index([user_id, type, sent_at])
  @@map("push_logs")
}

model SpendingDnaReport {
  id           String   @id @default(uuid())
  user_id      String
  month        String // "2026-01" format
  report_text  String // Full 3-paragraph AI report
  key_metrics  Json // { avg_daily_card_spend, savings_rate, biggest_leak }
  generated_at DateTime @default(now())

  @@unique([user_id, month])
  @@map("spending_dna_reports")
}


// ============================================================
// COMMUNITY — UX Psychology Report #5: Contribution Loops
// ============================================================

enum WinVisibility {
  circle
  public
}

model CommunityWin {
  id         String        @id @default(uuid())
  user_id    String
  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  action     String
  visibility WinVisibility @default(public)
  created_at DateTime      @default(now())

  @@index([visibility, created_at])
  @@map("community_wins")
}

// ============================================================
// PREFERENCES — UX Psychology Report #4: Personalization
// ============================================================

model UserPreferences {
  id                   String   @id @default(uuid())
  user_id              String   @unique
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  home_modules         String[] @default(["hero","milestone","trustcues","secondary"])
  notification_cadence String   @default("weekly")
  motivational_tone    String   @default("direct")
  currency             String   @default("USD")
  first_day_of_week    Int      @default(1)
  updated_at           DateTime @updatedAt
  created_at           DateTime @default(now())

  @@map("user_preferences")
}

// AI request ledger for the per-user sliding-window rate limiter. One row per
// chargeable AI call (chat, EOD insight, spending DNA). The counter query is
// `count(*) where user_id = $1 and created_at > now() - interval '1 hour'`,
// which is index-served by the composite below. Old rows are pruned by a
// best-effort retention sweep after each insert (see ai-rate-limit.service).
//
// Why a row-per-call ledger instead of a counter row with a reset_at:
// horizontally-safe (any web VM can read/write without coordination), gives
// per-call audit trail for support, and the retention sweep keeps the table
// small enough that the count() query stays sub-ms in practice.
model AIRequestLog {
  id         String   @id @default(uuid())
  user_id    String
  endpoint   String // 'chat' | 'eod_insight' | 'spending_dna'
  created_at DateTime @default(now())

  @@index([user_id, created_at])
  @@map("ai_request_logs")
}

// Server-side last-known-good cache used by AICircuitBreakerService when the
// upstream Perplexity gateway trips OPEN. Every row is a successful upstream
// response captured by the breaker on the happy path; reads never block the
// upstream call. See prisma/migrations/20260508000000_ai_response_cache for
// the read-path strategy and index rationale.
model AiResponseCache {
  id            String   @id @default(uuid())
  intent        String // 'chat' | 'eod_insight' | 'spending_dna'
  context_hash  String // sha256 of the canonicalised input — see ai-response-cache.service.ts
  response_text String
  model         String // model that produced the response, e.g. 'sonar-pro'
  created_at    DateTime @default(now())
  last_used_at  DateTime @default(now())

  @@unique([intent, context_hash])
  @@index([intent, last_used_at(sort: Desc)])
  @@map("ai_response_cache")
}

// ============================================================
// STAGE 2 — Coach Operating System
// ============================================================

// ClientAssignment: a task or challenge a coach assigns to a client.
// Examples: "Save $500 by Friday", "Pay extra $200 toward debt this week",
// "Track every coffee purchase for 14 days". The coach defines the
// assignment, the client sees it on their home, marks it done, and the
// coach sees completion status in their dashboard.
//
// Why a model and not a free-text note: assignments need state (open /
// completed / dismissed), a due_date for nudges, and they show up on
// both the coach view (compliance) and the client home (focus). Notes
// are coach-only memory; assignments are a two-sided contract.
enum AssignmentStatus {
  open
  completed
  dismissed
}

enum AssignmentType {
  budget
  savings_challenge
  debt_paydown
  habit
  custom
}

model ClientAssignment {
  id          String           @id @default(uuid())
  coach_id    String
  coach       User             @relation("AssignmentsByCoach", fields: [coach_id], references: [id])
  client_id   String
  client      User             @relation("AssignmentsForClient", fields: [client_id], references: [id], onDelete: Cascade)
  title       String
  description String?
  assignment_type AssignmentType @default(custom)
  due_date    DateTime?
  status      AssignmentStatus @default(open)
  // Optional structured target for budget / savings challenges. For a
  // savings challenge it's the dollar target; for a habit it can be the
  // streak count. Stored as Decimal so we can keep money values precise.
  target_value Decimal?         @db.Decimal(14, 2)
  target_unit  String? // e.g. 'usd', 'days', 'count'
  // Coach private context that doesn't surface to the client. Useful for
  // attaching reasoning the coach wants to remember without confusing
  // the client UI.
  coach_notes String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  completed_at DateTime?

  @@index([client_id, status])
  @@index([coach_id, created_at(sort: Desc)])
  @@map("client_assignments")
}

// CoachMessage: durable chat messages between coach and client.
// Stage 2 ships read + write APIs and the thread UI. Real-time delivery
// (websockets / push fan-out) lands in Stage 3 — for now a coach reading
// the thread re-fetches via the inbox/thread endpoints. The model is
// unidirectional (sender + recipient) so the inbox query is a single
// findMany on (recipient_id OR sender_id) with the per-thread reduction
// happening in the service layer.
model CoachMessage {
  id           String   @id @default(uuid())
  thread_key   String // canonical pair key — sorted "<a>:<b>" — used to group messages into threads
  sender_id    String
  sender       User     @relation("CoachMessagesSent", fields: [sender_id], references: [id])
  recipient_id String
  recipient    User     @relation("CoachMessagesReceived", fields: [recipient_id], references: [id])
  body         String
  // Read-state tracking. We only flip read_at on a recipient fetch; the
  // sender's view never marks as read on their own send.
  read_at      DateTime?
  created_at   DateTime @default(now())

  @@index([thread_key, created_at])
  @@index([recipient_id, read_at])
  @@map("coach_messages")
}

// CommunityPost: coach-authored content surfaced in the client community
// feed. The Stage 2 implementation is intentionally simple — title + body
// + optional URL (e.g. YouTube link). Stage 3 may add scheduled
// publishing, segmentation, or reactions.
enum CommunityPostStatus {
  draft
  published
  archived
}

model CommunityPost {
  id          String              @id @default(uuid())
  author_id   String
  author      User                @relation("CommunityPostsAuthored", fields: [author_id], references: [id])
  title       String
  body        String
  // Optional resource link — YouTube video, Substack article, etc. The
  // client surfaces it as a single tap-out card; we deliberately do not
  // try to inline-render arbitrary URLs.
  resource_url String?
  status      CommunityPostStatus @default(published)
  // Coach posts are visible to that coach's clients by default. An owner
  // post can set `audience` to 'all_clients' to broadcast across coaches.
  audience    String              @default("own_clients")
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  published_at DateTime?

  @@index([author_id, status, published_at(sort: Desc)])
  @@map("community_posts")
}

// Sprint A — multi-code invite flow.
//
// CoachProfile.invite_code is the coach's single default share link.
// InviteCode lets coaches mint additional, capped, time-bounded codes
// (e.g. for cohorts, paid-program windows, or one-shot reactivation
// links). Mirrors the fitness backend's contract so the mobile screen
// is portable across both products.
model InviteCode {
  id          String    @id @default(uuid())
  code        String    @unique
  coach_id    String
  coach       User      @relation("InviteCodesByCoach", fields: [coach_id], references: [id], onDelete: Cascade)
  expires_at  DateTime?
  max_uses    Int?
  used_count  Int       @default(0)
  revoked     Boolean   @default(false)
  created_at  DateTime  @default(now())

  @@index([coach_id, created_at(sort: Desc)])
  @@map("invite_codes")
}

// Sprint A — coach promotion audit trail.
//
// Every successful or failed coach self-promotion attempt via the
// signed-token endpoint logs here. Lets ops detect leaked secrets,
// chargeback fraud, and downstream support tickets without
// reconstructing intent from raw access logs.
model CoachPromotionAudit {
  id          String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  outcome    String   // success | invalid_token | already_coach | rate_limited | invalid_role
  reason     String?
  ip         String?
  user_agent String?
  created_at DateTime @default(now())

  @@index([user_id, created_at(sort: Desc)])
  @@index([outcome, created_at(sort: Desc)])
  @@map("coach_promotion_audits")
}
