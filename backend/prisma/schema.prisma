// The Growth Project: Finance — Prisma Schema
// PostgreSQL with multi-tenant architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  coach
  student
  owner
}

enum AccountType {
  checking
  savings
  investment_brokerage
  retirement_401k
  retirement_ira
  real_estate
  vehicle
  other_asset
  credit_card
  personal_loan
  student_loan
  auto_loan
  mortgage
  medical_debt
  other_debt
}

enum RiskTolerance {
  conservative
  moderate
  aggressive
}

enum MotivationStyle {
  small_wins
  big_picture
}

enum LogSource {
  eod_form
  manual_update
  onboarding
}

enum ScenarioType {
  extra_debt_payment
  income_increase
  relocate_country
  relocate_city
  cut_expense
  invest_lump_sum
  sell_asset
  start_business
  pay_off_debt_early
  salary_negotiation
  tax_optimization
  retire_early
}

// ProofKind: what kind of progress proof a user is submitting. Kept narrow
// and explicit on purpose — every new kind needs its own validator and its
// own coach/admin review path.
enum ProofKind {
  net_worth_milestone   // user-claimed net worth threshold, needs coach signoff
  finance_screenshot    // bank/brokerage/payroll screenshot
  income_statement      // pay stub, 1099, contract receipt
  bank_statement        // multi-line statement
  platform_payout       // Stripe/Plaid/PayPal payout snapshot
  fitness_metric        // weight/lift/body comp, coach-verified
  habit_consistency     // streaks/check-ins, app-derived
  coach_report          // coach-authored progress report
  admin_report          // admin-authored audit/note
  self_report           // user-attested, no document
  milestone_review      // coach review of an auto-unlocked milestone
}

enum ProofStatus {
  pending_review        // submitted, no human has touched it
  coach_signed_off      // coach has reviewed and approved
  coach_rejected        // coach has reviewed and rejected
  admin_reviewed        // admin has performed a higher-tier review
  disputed              // user or coach has flagged a dispute
  flagged_abuse         // moderation: suspected fraud / misuse
  stale                 // source data is too old to trust
  superseded            // replaced by a newer artifact for the same claim
}

enum ProofSource {
  user_upload           // user uploaded a screenshot or document
  app_derived           // computed from in-app data (logs, EOD, accounts)
  coach_entered         // coach typed/uploaded on student's behalf
  admin_entered         // admin/owner action
  external_link         // URL to external system (read-only reference)
}

enum ProofAuditAction {
  submitted
  viewed
  coach_signoff
  coach_rejection
  admin_review
  dispute_opened
  dispute_resolved
  abuse_flag_raised
  abuse_flag_cleared
  marked_stale
  superseded
  ai_draft_generated
  ai_draft_dismissed
  amount_corrected
}

// ============================================================
// MODELS
// ============================================================

model User {
  id            String   @id @default(uuid())
  supabase_id   String   @unique
  email         String   @unique
  name          String
  phone         String?
  referral_code String?
  role          Role     @default(student)
  coach_id      String? // For students: which coach manages them
  created_at    DateTime @default(now())

  // Relations
  profile              FinancialProfile?
  accounts             FinancialAccount[]
  eod_submissions      EODSubmission[]
  what_if_scenarios    WhatIfScenario[]
  notification_prefs   NotificationPreferences?
  habit_logs           HabitLog[]
  milestones           MilestoneUnlock[]
  accountability_pair  String? // partner user_id (privacy: only scores/streaks shown)
  coach_notes_received CoachNote[]              @relation("StudentNotes")
  coach_notes_sent     CoachNote[]              @relation("CoachNotes")
  program_templates    ProgramTemplate[]
  community_wins       CommunityWin[]
  preferences          UserPreferences?
  coach_profile        CoachProfile?
  proof_artifacts      ProofArtifact[]      @relation("ProofSubject")
  proof_signoffs       ProofArtifact[]      @relation("ProofReviewer")
  proof_audit_entries  ProofAuditLog[]      @relation("ProofAuditActor")

  @@map("users")
}

// CoachProfile: per-coach tenant metadata. Created when a user is promoted to
// `coach` (or `owner`) and is the source of truth for the coach's invite_code,
// which is the share-link token clients use to sign up under that coach.
//
// Why a separate table:
//  - keeps invite_code/display_name out of User (which all users share)
//  - lets us add coach-only fields (capacity, billing hooks) without bloating User
//  - admin/owner promotion can ensure-create this row idempotently
model CoachProfile {
  id           String   @id @default(uuid())
  user_id      String   @unique
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  invite_code  String   @unique
  display_name String?
  bio          String?
  is_active    Boolean  @default(true)
  capacity     Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("coach_profiles")
}

model FinancialProfile {
  id                      String          @id @default(uuid())
  user_id                 String          @unique
  user                    User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  state                   String?
  city                    String?
  country                 String          @default("United States")
  monthly_income_gross    Decimal?        @db.Decimal(14, 2)
  annual_income_gross     Decimal?        @db.Decimal(14, 2)
  income_sources          Json? // array of { source, amount, frequency }
  primary_goal            String?
  goal_timeline_months    Int?
  dream_lifestyle_cost_mo Decimal?        @db.Decimal(14, 2)
  dream_description       String?
  future_self_letter      String? // Written during onboarding, revealed at day 90
  risk_tolerance          RiskTolerance   @default(moderate)
  is_self_employed        Boolean         @default(false)
  has_business            Boolean         @default(false)
  motivation_style        MotivationStyle @default(big_picture)
  net_worth_snapshot      Decimal?        @db.Decimal(14, 2) // Updated on every EOD submission
  total_debt              Decimal?        @db.Decimal(14, 2) // Computed sum of all debt balances
  total_assets            Decimal?        @db.Decimal(14, 2) // Computed sum of all asset balances
  total_cash              Decimal?        @db.Decimal(14, 2) // Computed sum of checking + savings
  current_priority_index  Int             @default(0) // Index in PRIORITY_WATERFALL
  wealth_velocity_score   Float? // 0-100, updated daily — score, not money
  last_eod_date           DateTime?
  filing_status           String          @default("single") // for tax estimator
  onboarding_complete     Boolean         @default(false)
  payday_templates        Json? // array of { id, name, allocations: [{account_id, percentage}], created_at }
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt

  @@map("financial_profiles")
}

model FinancialAccount {
  id              String              @id @default(uuid())
  user_id         String
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name            String // e.g., "Chase Sapphire", "Car Loan", "Roth IRA"
  account_type    AccountType
  institution     String?
  balance         Decimal             @db.Decimal(14, 2) // Current balance (positive for assets AND debt)
  is_debt         Boolean             @default(false)
  apr_percent     Float? // For debt accounts — percentage, not money
  is_secured      Boolean? // true for mortgage/car, false for credit card/personal loan
  minimum_payment Decimal?            @db.Decimal(14, 2)
  currency        String              @default("USD")
  notes           String?
  is_active       Boolean             @default(true)
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  balance_logs    AccountBalanceLog[]

  @@map("financial_accounts")
}

model AccountBalanceLog {
  id         String           @id @default(uuid())
  account_id String
  account    FinancialAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  balance    Decimal          @db.Decimal(14, 2)
  date       DateTime         @db.Date
  logged_at  DateTime         @default(now())
  source     LogSource        @default(eod_form)

  @@map("account_balance_logs")
}

model EODSubmission {
  id                    String   @id @default(uuid())
  user_id               String
  user                  User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  submission_date       DateTime @db.Date
  account_snapshots     Json // array of { account_id, balance, notes }
  net_worth_computed    Decimal  @db.Decimal(14, 2)
  total_debt_computed   Decimal  @db.Decimal(14, 2)
  total_assets_computed Decimal  @db.Decimal(14, 2)
  total_cash_computed   Decimal  @db.Decimal(14, 2)
  notes                 String?
  mood                  Int? // 1-5 optional
  ai_insight            String? // AI-generated insight after submission
  habits_checked        Json? // array of checked habit keys
  submitted_at          DateTime @default(now())

  @@unique([user_id, submission_date])
  @@map("eod_submissions")
}

model WhatIfScenario {
  id              String       @id @default(uuid())
  user_id         String
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  scenario_type   ScenarioType
  label           String
  parameters      Json // Flexible key-value for scenario inputs
  result_summary  Json // Computed outputs
  projection_1yr  Decimal?     @db.Decimal(14, 2)
  projection_3yr  Decimal?     @db.Decimal(14, 2)
  projection_5yr  Decimal?     @db.Decimal(14, 2)
  projection_10yr Decimal?     @db.Decimal(14, 2)
  created_at      DateTime     @default(now())

  @@map("what_if_scenarios")
}

model MilestoneUnlock {
  id            String   @id @default(uuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  milestone_key String
  unlocked_at   DateTime @default(now())
  celebrated    Boolean  @default(false)

  @@unique([user_id, milestone_key])
  @@map("milestone_unlocks")
}

model NotificationPreferences {
  id                          String  @id @default(uuid())
  user_id                     String  @unique
  user                        User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  eod_reminder_enabled        Boolean @default(true)
  eod_reminder_time           String  @default("20:00")
  milestone_alerts            Boolean @default(true)
  coach_messages              Boolean @default(true)
  red_flag_alerts             Boolean @default(true)
  future_self_letter_enabled  Boolean @default(true)
  priority_levelup_alerts     Boolean @default(true)
  spending_dna_alerts         Boolean @default(true)
  timezone                    String  @default("America/Los_Angeles")
  expo_push_token             String? // For Expo push notifications

  @@map("notification_preferences")
}

model HabitLog {
  id        String   @id @default(uuid())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  habit_key String // e.g., "no_impulse_buy", "checked_balances", "reviewed_budget"
  date      DateTime @db.Date
  completed Boolean  @default(true)
  logged_at DateTime @default(now())

  @@unique([user_id, habit_key, date])
  @@map("habit_logs")
}

model CoachNote {
  id         String   @id @default(uuid())
  coach_id   String
  coach      User     @relation("CoachNotes", fields: [coach_id], references: [id])
  student_id String
  student    User     @relation("StudentNotes", fields: [student_id], references: [id])
  note       String
  is_private Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("coach_notes")
}

model ProgramTemplate {
  id          String   @id @default(uuid())
  coach_id    String
  coach       User     @relation(fields: [coach_id], references: [id])
  name        String
  description String?
  phases      Json // array of { phase_name, priority_index, duration_weeks, notes }
  created_at  DateTime @default(now())

  @@map("program_templates")
}

model PushLog {
  id      String   @id @default(uuid())
  user_id String
  type    String // e.g., eod_reminder, net_worth_milestone, priority_levelup, future_self_letter, spending_dna
  title   String
  body    String
  data    Json? // arbitrary payload (milestone key, priority index, etc.) — used for event-dedupe
  sent_at DateTime @default(now())
  error   String?

  @@index([user_id, type, sent_at])
  @@map("push_logs")
}

model SpendingDnaReport {
  id           String   @id @default(uuid())
  user_id      String
  month        String // "2026-01" format
  report_text  String // Full 3-paragraph AI report
  key_metrics  Json // { avg_daily_card_spend, savings_rate, biggest_leak }
  generated_at DateTime @default(now())

  @@unique([user_id, month])
  @@map("spending_dna_reports")
}


// ============================================================
// COMMUNITY — UX Psychology Report #5: Contribution Loops
// ============================================================

enum WinVisibility {
  circle
  public
}

model CommunityWin {
  id         String        @id @default(uuid())
  user_id    String
  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  action     String
  visibility WinVisibility @default(public)
  created_at DateTime      @default(now())

  @@index([visibility, created_at])
  @@map("community_wins")
}

// ============================================================
// PREFERENCES — UX Psychology Report #4: Personalization
// ============================================================

model UserPreferences {
  id                   String   @id @default(uuid())
  user_id              String   @unique
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  home_modules         String[] @default(["hero","milestone","trustcues","secondary"])
  notification_cadence String   @default("weekly")
  motivational_tone    String   @default("direct")
  currency             String   @default("USD")
  first_day_of_week    Int      @default(1)
  updated_at           DateTime @updatedAt
  created_at           DateTime @default(now())

  @@map("user_preferences")
}

// AI request ledger for the per-user sliding-window rate limiter. One row per
// chargeable AI call (chat, EOD insight, spending DNA). The counter query is
// `count(*) where user_id = $1 and created_at > now() - interval '1 hour'`,
// which is index-served by the composite below. Old rows are pruned by a
// best-effort retention sweep after each insert (see ai-rate-limit.service).
//
// Why a row-per-call ledger instead of a counter row with a reset_at:
// horizontally-safe (any web VM can read/write without coordination), gives
// per-call audit trail for support, and the retention sweep keeps the table
// small enough that the count() query stays sub-ms in practice.
model AIRequestLog {
  id         String   @id @default(uuid())
  user_id    String
  endpoint   String // 'chat' | 'eod_insight' | 'spending_dna'
  created_at DateTime @default(now())

  @@index([user_id, created_at])
  @@map("ai_request_logs")
}


// ============================================================
// PROOF — verified-progress rails
// ============================================================
//
// `ProofArtifact` is a single piece of evidence a student (or coach/admin
// on a student's behalf) submits to back a claim — net worth milestone,
// income statement, fitness metric, login streak. The row is the artifact;
// the surrounding `ProofSignoff` and `ProofAuditLog` rows are the
// trust/audit chain.
//
// Trust model:
//   - Submission alone never proves anything. Status starts at
//     `pending_review`.
//   - Coach signoff promotes status to `coach_signed_off`. Coach signoff is
//     the bar for showing the artifact in client-facing aggregates.
//   - Admin review (`admin_reviewed`) is a higher tier used for disputes
//     and high-value claims (e.g. NW > $250k milestones).
//   - `disputed` and `flagged_abuse` are moderation states that *block*
//     downstream consumption — neither AI summaries nor client-facing
//     aggregates may treat a flagged artifact as authoritative.
//
// Money fields use `Decimal(14, 2)` per backend/docs/MONEY.md. JSON columns
// store source metadata (URLs, file refs, derived inputs) — they are
// validated by the Zod contracts in src/proof/contracts.ts before write.
model ProofArtifact {
  id                  String       @id @default(uuid())
  // Subject = the student the proof is *about*. Always required.
  user_id             String
  user                User         @relation("ProofSubject", fields: [user_id], references: [id], onDelete: Cascade)
  // Reviewer = the coach or admin currently responsible for this artifact.
  // Nullable: an unreviewed artifact has no reviewer yet.
  reviewer_id         String?
  reviewer            User?        @relation("ProofReviewer", fields: [reviewer_id], references: [id])
  kind                ProofKind
  status              ProofStatus  @default(pending_review)
  source              ProofSource
  // The claim the artifact backs. For milestones this is the milestone_key;
  // for finance proof it is a free-text label ("April pay stub"). Free-form
  // because milestone keys, kpi names, and external claims do not share a
  // single namespace.
  claim_label         String
  // Money amount the artifact attests to, when applicable. Net worth
  // milestones, income statements, payouts. Nullable for self-reports and
  // habit consistency where the proof is not numeric.
  claimed_amount      Decimal?     @db.Decimal(14, 2)
  // Currency for `claimed_amount`. ISO 4217. Defaults to USD; multi-currency
  // is not supported by downstream aggregates yet (flagged in README).
  currency            String       @default("USD")
  // ISO date of the underlying record (statement date, milestone date).
  // Distinct from `submitted_at` (when the user uploaded). Used to detect
  // staleness — artifacts older than the staleness threshold (configurable
  // per kind) get auto-marked `stale`.
  occurred_at         DateTime     @db.Date
  submitted_at        DateTime     @default(now())
  reviewed_at         DateTime?
  // Source metadata: opaque JSON blob validated by the Zod contracts
  // before write. Shape varies by `source`:
  //   user_upload    -> { storage_ref, mime_type, sha256, byte_size }
  //   app_derived    -> { derived_from: 'eod'|'habit_logs'|..., from_id }
  //   coach_entered  -> { entered_by_coach_id, note }
  //   admin_entered  -> { entered_by_admin_id, reason }
  //   external_link  -> { url, captured_at }
  source_metadata     Json
  // Free-text user note. Coach/admin notes go on signoff rows.
  user_note           String?
  // Abuse / dispute flags. `dispute_reason` is set when a coach or user
  // opens a dispute; `abuse_flag_reason` when moderation flags fraud.
  dispute_reason      String?
  abuse_flag_reason   String?
  // Set when `status = stale`. Records the staleness threshold the
  // artifact tripped, in days, so the audit trail is reproducible even if
  // the threshold config changes later.
  stale_after_days    Int?
  // Set when `status = superseded`. Points at the artifact that replaced it.
  superseded_by_id    String?
  signoffs            ProofSignoff[]
  audit_log           ProofAuditLog[]
  ai_drafts           ProofAIDraft[]
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  @@index([user_id, kind, status])
  @@index([reviewer_id, status])
  @@index([status, occurred_at])
  @@map("proof_artifacts")
}

// ProofSignoff: a single coach or admin acting on an artifact. One artifact
// can accumulate multiple signoffs (initial coach review, follow-up admin
// review, dispute resolution). Each row is immutable — corrections create a
// new signoff with `supersedes_id` set, not an UPDATE.
model ProofSignoff {
  id              String        @id @default(uuid())
  artifact_id     String
  artifact        ProofArtifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  // The reviewer (coach or admin). We don't relation-link here because the
  // FK pulls a duplicate `User` relation set into the schema — keep it as a
  // plain id and resolve at read time.
  reviewer_id     String
  reviewer_role   String        // 'coach' | 'admin' | 'owner' (snapshot at signoff time)
  decision        ProofStatus   // coach_signed_off | coach_rejected | admin_reviewed | disputed
  note            String?
  supersedes_id   String?       // points at the prior signoff this one replaces
  created_at      DateTime      @default(now())

  @@index([artifact_id, created_at])
  @@map("proof_signoffs")
}

// ProofAuditLog: append-only event stream for an artifact. Every state
// transition, view, signoff, dispute, abuse flag, and AI draft event lands
// here. The other proof tables can be reconstructed from this log if needed.
model ProofAuditLog {
  id           String           @id @default(uuid())
  artifact_id  String
  artifact     ProofArtifact    @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  actor_id     String?          // null for system actions (staleness sweep, AI)
  actor        User?            @relation("ProofAuditActor", fields: [actor_id], references: [id])
  actor_role   String           // 'student' | 'coach' | 'admin' | 'owner' | 'system' | 'ai'
  action       ProofAuditAction
  // Snapshot of the field(s) that changed. Free-form by design — the audit
  // log is for humans, not for replay. Keep payloads small.
  detail       Json?
  created_at   DateTime         @default(now())

  @@index([artifact_id, created_at])
  @@index([actor_id, created_at])
  @@map("proof_audit_logs")
}

// ProofAIDraft: an AI-generated *advisory* note attached to an artifact.
// Drafts are never authoritative — they are suggestions a coach or admin
// can copy into their own signoff note. Storing them lets us show provenance
// ("AI draft, dismissed by coach") in the audit log.
//
// Hard rules (enforced in src/proof/proof-ai.service.ts):
//   - AI may produce: summary, missing/stale flags, contradiction flags,
//     draft note text.
//   - AI may NOT: change `status`, write a `ProofSignoff`, alter
//     `claimed_amount`, mark anything `coach_signed_off`/`admin_reviewed`,
//     or trigger any payout/notification side-effect.
model ProofAIDraft {
  id              String        @id @default(uuid())
  artifact_id     String
  artifact        ProofArtifact @relation(fields: [artifact_id], references: [id], onDelete: Cascade)
  // 'summary' | 'missing_data_flag' | 'stale_data_flag' | 'contradiction_flag'
  // | 'coach_note_draft' | 'admin_note_draft'
  draft_kind      String
  // The model + prompt version used. Snapshot at generation time so
  // post-hoc audits can pin behaviour to a specific revision.
  model_label     String
  prompt_version  String
  // The draft text shown to a human reviewer. Plain text; no markdown
  // execution, no tool-call payloads.
  draft_text      String
  // Set when a coach/admin dismisses or accepts the draft.
  resolved_by_id  String?
  resolved_action String?       // 'accepted' | 'dismissed' | 'edited'
  resolved_at     DateTime?
  created_at      DateTime      @default(now())

  @@index([artifact_id, created_at])
  @@map("proof_ai_drafts")
}
