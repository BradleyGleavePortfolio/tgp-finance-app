# ============================================================
# THE GROWTH PROJECT: FINANCE — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
# See README.md for where to get each key.
# ============================================================

# PostgreSQL — Create on Supabase free tier; copy connection string from Settings → Database.
DATABASE_URL=your_postgresql_connection_string_here

# Supabase Auth — Supabase dashboard → Settings → API → copy URL and keys.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Perplexity AI Coach — perplexity.ai → Settings → API → Generate Key.
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# JWT — Generate a random 32+ character secret (e.g., openssl rand -hex 32).
JWT_SECRET=your_jwt_secret_32_chars_min_here

# Google OAuth — console.cloud.google.com → Create Project → Credentials → OAuth 2.0 Client IDs.
GOOGLE_CLIENT_ID_IOS=your_google_ios_client_id_here
GOOGLE_CLIENT_ID_ANDROID=your_google_android_client_id_here
GOOGLE_CLIENT_ID_WEB=your_google_web_client_id_here

# Numbeo API (optional) — numbeo.com/api → register for API access. Free tier available.
NUMBEO_API_KEY=your_numbeo_api_key_here_optional

# Coach self-promotion backdoor (DEV ONLY — NEVER SET IN PRODUCTION).
# When ENABLE_DEV_BACKDOOR=true AND NODE_ENV != production AND COACH_ACCESS_CODE is set,
# the /api/auth/select-role endpoint accepts COACH_ACCESS_CODE to grant coach role.
# In production, leave these unset; grant coach role via an admin tool / direct DB update.
ENABLE_DEV_BACKDOOR=false
COACH_ACCESS_CODE=

# CORS — comma-separated allow-list of origins permitted to call the API. Default covers
# local Expo dev (http://localhost:8081 web, http://localhost:19006 dev menu).
# In production set to your real origins only — never leave this open.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Server
PORT=3000
NODE_ENV=development

# ============================================================
# Mobile (Expo) — prefix with EXPO_PUBLIC_ so they reach the client bundle.
# These MUST be set for the mobile build to start; hardcoded prod fallbacks
# were removed in the round-2 stability PR.
# ============================================================
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
